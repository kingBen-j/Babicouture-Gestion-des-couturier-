# ============================================
# BabiCouture Configuration Example
# Copier vers .env et adapter les valeurs
# ============================================

# ============================================
# Django Configuration
# ============================================
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production-with-something-very-long-and-random
ALLOWED_HOSTS=localhost,127.0.0.1,babicouture.local

# ============================================
# Database Configuration
# ============================================

# Option 1: SQLite (Développement)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3

# Option 2: PostgreSQL (Production - Décommenter et configurer)
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=babicouture
# DB_USER=postgres
# DB_PASSWORD=your-secure-password-here
# DB_HOST=localhost
# DB_PORT=5432

# ============================================
# Email Configuration
# ============================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-specific-password

# ============================================
# AWS S3 Configuration (pour fichiers média)
# ============================================
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=babicouture-media
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=your-domain.s3.amazonaws.com

# ============================================
# Redis Configuration (Cache & Message Queue)
# ============================================
REDIS_URL=redis://localhost:6379/0
# REDIS_URL=redis://:password@localhost:6379/0

# ============================================
# Security (Production)
# ============================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_BROWSER_XSS_FILTER=True
SECURE_CONTENT_SECURITY_POLICY=False
X_FRAME_OPTIONS=DENY

# ============================================
# Timezone
# ============================================
TIME_ZONE=Africa/Abidjan

# ============================================
# API Keys & External Services
# ============================================
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# PAYPAL_CLIENT_ID=...
# SENTRY_DSN=...

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO

# ============================================
# Application Settings
# ============================================
LANGUAGE_CODE=fr-fr
USE_I18N=True
USE_TZ=True

# ============================================
# API Gateway Ports
# ============================================
API_USERS_PORT=8001
API_CATALOG_PORT=8002
API_ORDERS_PORT=8003
API_MESSAGING_PORT=8004
API_REVIEWS_PORT=8005
API_CORE_PORT=8006

# ============================================
# Celery (Task Queue)
# ============================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_ACCEPT_CONTENT=json
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
